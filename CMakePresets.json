{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "debug",
      "inherits": ["base"],
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": ["base"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "targets": ["all"]
    },
    {
      "name": "release",
      "configurePreset": "release",
      "targets": ["all"]
    },
    {
      "name": "tests",
      "configurePreset": "release",
      "targets": ["unit_tests"]
    }
  ],
  "testPresets": [
    {
      "name": "run-tests",
      "description": "Runs all tests with CTest",
      "configurePreset": "release",
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false,
        "jobs": 8
      },
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": ".*"
        }
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "ci",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "tests"
        },
        {
          "type": "test",
          "name": "run-tests"
        }
      ]
    }
  ]
}
